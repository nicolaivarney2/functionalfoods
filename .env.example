# API Keys (Required to enable respective provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI models. Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional, for Mistral AI models.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional, for xAI AI models.
GROQ_API_KEY="YOUR_GROQ_KEY_HERE"                     # Optional, for Groq models.
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"         # Optional, for OpenRouter models.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional, for Azure OpenAI models (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require authentication.
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub import/export features. Format: ghp_... or github_pat_...

# Smart shopping (SMS til indkøbslink) – se https://docs.sms.dk/
SMS_DK_API_KEY=""                                     # Påkrævet for at sende SMS fra Madbudget
SMS_DK_SENDER="Velia"                                 # eller +4593700413 – skal matche godkendt afsender i sms.dk
# SMS_DK_API_BASE="https://api.sms.dk"               # Kun hvis sms.dk peger et andet sted hen

# Turnstile i UI ved signup (ikke ved login). I Supabase: Authentication → Bot and Abuse Protection:
# Slå "Enable Captcha protection" FRA for at login virker uden token. (Supabase kan ikke kun kræve signup.)
# Cloudflare Turnstile site key + secret i Supabase kan fjernes hvis global captcha er fra.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# Turnstile secret til Supabase Auth hook / server (hvis I validerer server-side)
# TURNSTILE_SECRET_KEY="" 

# Nyhedsbrev (blog widgets): forskellige formular-URL pr. kategori (ConvertKit / Mailchimp m.fl. action-URL)
# NEXT_PUBLIC_NEWSLETTER_FORM_DEFAULT=""
# NEXT_PUBLIC_NEWSLETTER_FORM_KETO=""
# NEXT_PUBLIC_NEWSLETTER_FORM_SENSE=""
# NEXT_PUBLIC_NEWSLETTER_FORM_MENTALT=""

# Opskriftsside: visnings-boost for besøgstal (×3 indtil dato; standard 2026-12-31 hvis udeladt)
# NEXT_PUBLIC_RECIPE_VIEW_BOOST_UNTIL="2026-12-31"
# NEXT_PUBLIC_RECIPE_VIEW_BOOST_MULTIPLIER="3"

# Valgfri Zapier/Make (ekstra kopi af tilmelding — kan bruges sammen med Loops)
# NEWSLETTER_ZAPIER_WEBHOOK_URL=""

# Loops (loops.so) — direkte tilmelding via API (anbefalet frem for at eksponere API-nøgle i browser)
# Opret nøgle under Settings → API. Mailing list-id: Loops → Audience → Mailing lists → id pr. liste.
# LOOPS_API_KEY=""
# LOOPS_MAILING_LIST_DEFAULT=""
# LOOPS_MAILING_LIST_KETO=""
# LOOPS_MAILING_LIST_SENSE=""
# LOOPS_MAILING_LIST_MENTALT=""
# LOOPS_MAILING_LIST_GLP_1=""
# LOOPS_MAILING_LIST_FLEXITARIAN=""
# LOOPS_MAILING_LIST_FAMILIE=""
# LOOPS_MAILING_LIST_ANTI_INFLAMMATORY=""
# LOOPS_MAILING_LIST_5_2_DIET=""
# LOOPS_MAILING_LIST_PROTEINRIG_KOST=""
# Interesseliste: trykt 6-ugers vægttabsbog (wizard) — falder tilbage til LOOPS_MAILING_LIST_DEFAULT hvis tom
# LOOPS_MAILING_LIST_VAEGTTABSBOG=""

# Facebook Messenger (ManyChat): numerisk Page ID. Logget-ind widget "Personlig vejledning" vises kun når sat.
# NEXT_PUBLIC_MESSENGER_PAGE_ID="123456789012345"
#
# Server (webhook + API — kun på server, ikke NEXT_PUBLIC):
# MANYCHAT_API_KEY=""                    # Settings → API i ManyChat; til setCustomFields
# MANYCHAT_WEBHOOK_SECRET=""             # Valgfri; sæt samme hemmelighed i ManyChat "External request" header X-FF-Webhook-Secret
# MANYCHAT_FIELD_FF_USER_ID=""           # Numeric custom field id i ManyChat (FF bruger-id)
# MANYCHAT_FIELD_AGENT_SUMMARY=""        # Numeric custom field id (kort agent-konteksttekst)
#
# DB: kør add-manychat-integration.sql i Supabase (messenger_link_tokens + manychat_* kolonner).
# Opsætning: se docs/manychat-setup.md

# Forside hero: MP4-URL eller YouTube-link (valgfri). Uden værdi vises en pæn placeholder.
# NEXT_PUBLIC_HOME_HERO_VIDEO_URL="https://www.youtube.com/watch?v=XXXXXXXXXXX"
# NEXT_PUBLIC_HOME_HERO_VIDEO_URL="https://example.com/intro.mp4"