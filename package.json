{
  "name": "functionalfoods",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/post-merge .githooks/post-checkout 2>/dev/null || true",
    "env:pull": "node scripts/env-pull-safe.js",
    "env:check": "node scripts/check-env-local.js",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "fooddata:verify-uuid": "npx tsx scripts/verify-ingredient-uuid-overlap.ts",
    "fooddata:pull-curation": "npx tsx scripts/sync-fooddata-curation-to-ff.ts --pull-queue",
    "fooddata:sync-publish": "npx tsx scripts/sync-ff-to-fooddata.ts",
    "fooddata:sync-publish:dry-run": "npx tsx scripts/sync-ff-to-fooddata.ts --dry-run",
    "fooddata:import": "npx tsx scripts/import-fooddata-to-ff.ts",
    "fooddata:import:curation-only": "npx tsx scripts/import-fooddata-to-ff.ts --curation-only",
    "fooddata:weekly-curation": "npx tsx scripts/fooddata-weekly-curation.ts --app=ff",
    "fooddata:create-api-key": "npx tsx scripts/grocery-create-api-key.ts",
    "oko:scan-products": "npx tsx scripts/oko-scan-products.ts",
    "oko:scan-products:execute": "npx tsx scripts/oko-scan-products.ts --execute"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.53.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.0.1",
    "axios": "^1.11.0",
    "critters": "^0.0.23",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "framer-motion": "^12.23.12",
    "html2canvas": "^1.4.1",
    "jsdom": "^26.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.294.0",
    "next": "^15.5.9",
    "node-fetch": "^3.3.2",
    "openai": "^5.20.1",
    "pg": "^8.21.0",
    "postcss": "^8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.3",
    "stripe": "^17.7.0",
    "tailwindcss": "^3.3.0",
    "xlsx": "npm:@e965/xlsx@0.20.3"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "eslint-config-next": "^15.5.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "typescript": "^5"
  }
}

