{
  "$schema": "https://schemas.tokens.studio/latest/tokens-schema.json",
  "_meta": {
    "description": "Functional Foods design tokens. Mirror of design-system/tokens.js. Import this file in Figma via the Tokens Studio plugin (https://tokens.studio/).",
    "version": "0.1.0"
  },
  "color": {
    "neutral": {
      "0":   { "$type": "color", "$value": "#ffffff" },
      "50":  { "$type": "color", "$value": "#fafafa" },
      "100": { "$type": "color", "$value": "#f5f5f5" },
      "200": { "$type": "color", "$value": "#e5e5e5" },
      "300": { "$type": "color", "$value": "#d4d4d4" },
      "400": { "$type": "color", "$value": "#a3a3a3" },
      "500": { "$type": "color", "$value": "#737373" },
      "600": { "$type": "color", "$value": "#525252" },
      "700": { "$type": "color", "$value": "#404040" },
      "800": { "$type": "color", "$value": "#262626" },
      "900": { "$type": "color", "$value": "#171717" },
      "950": { "$type": "color", "$value": "#0a0a0a" }
    },
    "brand": {
      "50":  { "$type": "color", "$value": "#f3f7f3" },
      "100": { "$type": "color", "$value": "#e3eee5" },
      "200": { "$type": "color", "$value": "#c5dcc9" },
      "300": { "$type": "color", "$value": "#9cc1a2" },
      "400": { "$type": "color", "$value": "#6ea177" },
      "500": { "$type": "color", "$value": "#4c8556" },
      "600": { "$type": "color", "$value": "#3a6a43" },
      "700": { "$type": "color", "$value": "#305537" },
      "800": { "$type": "color", "$value": "#28452e" },
      "900": { "$type": "color", "$value": "#223a28" },
      "950": { "$type": "color", "$value": "#0f1f14" }
    },
    "accent": {
      "50":  { "$type": "color", "$value": "#fdf6f3" },
      "100": { "$type": "color", "$value": "#fbe8e0" },
      "200": { "$type": "color", "$value": "#f7cdbd" },
      "300": { "$type": "color", "$value": "#f0a78c" },
      "400": { "$type": "color", "$value": "#e87b59" },
      "500": { "$type": "color", "$value": "#dc5a36" },
      "600": { "$type": "color", "$value": "#c64627" },
      "700": { "$type": "color", "$value": "#a53721" },
      "800": { "$type": "color", "$value": "#852f20" },
      "900": { "$type": "color", "$value": "#6d2a1f" },
      "950": { "$type": "color", "$value": "#3b130c" }
    },
    "success": {
      "50":  { "$type": "color", "$value": "#f0fdf4" },
      "100": { "$type": "color", "$value": "#dcfce7" },
      "500": { "$type": "color", "$value": "#22c55e" },
      "600": { "$type": "color", "$value": "#16a34a" },
      "700": { "$type": "color", "$value": "#15803d" },
      "900": { "$type": "color", "$value": "#14532d" }
    },
    "warning": {
      "50":  { "$type": "color", "$value": "#fffbeb" },
      "100": { "$type": "color", "$value": "#fef3c7" },
      "500": { "$type": "color", "$value": "#f59e0b" },
      "600": { "$type": "color", "$value": "#d97706" },
      "700": { "$type": "color", "$value": "#b45309" },
      "900": { "$type": "color", "$value": "#78350f" }
    },
    "danger": {
      "50":  { "$type": "color", "$value": "#fef2f2" },
      "100": { "$type": "color", "$value": "#fee2e2" },
      "500": { "$type": "color", "$value": "#ef4444" },
      "600": { "$type": "color", "$value": "#dc2626" },
      "700": { "$type": "color", "$value": "#b91c1c" },
      "900": { "$type": "color", "$value": "#7f1d1d" }
    },
    "info": {
      "50":  { "$type": "color", "$value": "#eff6ff" },
      "100": { "$type": "color", "$value": "#dbeafe" },
      "500": { "$type": "color", "$value": "#3b82f6" },
      "600": { "$type": "color", "$value": "#2563eb" },
      "700": { "$type": "color", "$value": "#1d4ed8" },
      "900": { "$type": "color", "$value": "#1e3a8a" }
    },
    "dietary": {
      "keto":              { "$type": "color", "$value": "#7c3aed" },
      "paleo":             { "$type": "color", "$value": "#b45309" },
      "antiInflammatory":  { "$type": "color", "$value": "#0d9488" },
      "flexitarian":       { "$type": "color", "$value": "#65a30d" },
      "proteinRich":       { "$type": "color", "$value": "#dc2626" },
      "fiveTwo":           { "$type": "color", "$value": "#0284c7" },
      "glp1":              { "$type": "color", "$value": "#9333ea" },
      "sense":             { "$type": "color", "$value": "#0891b2" },
      "weightLoss":        { "$type": "color", "$value": "#db2777" },
      "calorieCounting":   { "$type": "color", "$value": "#ea580c" }
    }
  },
  "spacing": {
    "0":   { "$type": "dimension", "$value": "0px" },
    "px":  { "$type": "dimension", "$value": "1px" },
    "0.5": { "$type": "dimension", "$value": "2px" },
    "1":   { "$type": "dimension", "$value": "4px" },
    "1.5": { "$type": "dimension", "$value": "6px" },
    "2":   { "$type": "dimension", "$value": "8px" },
    "2.5": { "$type": "dimension", "$value": "10px" },
    "3":   { "$type": "dimension", "$value": "12px" },
    "3.5": { "$type": "dimension", "$value": "14px" },
    "4":   { "$type": "dimension", "$value": "16px" },
    "5":   { "$type": "dimension", "$value": "20px" },
    "6":   { "$type": "dimension", "$value": "24px" },
    "7":   { "$type": "dimension", "$value": "28px" },
    "8":   { "$type": "dimension", "$value": "32px" },
    "9":   { "$type": "dimension", "$value": "36px" },
    "10":  { "$type": "dimension", "$value": "40px" },
    "12":  { "$type": "dimension", "$value": "48px" },
    "14":  { "$type": "dimension", "$value": "56px" },
    "16":  { "$type": "dimension", "$value": "64px" },
    "20":  { "$type": "dimension", "$value": "80px" },
    "24":  { "$type": "dimension", "$value": "96px" },
    "32":  { "$type": "dimension", "$value": "128px" },
    "40":  { "$type": "dimension", "$value": "160px" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "xs":   { "$type": "dimension", "$value": "2px" },
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "8px" },
    "lg":   { "$type": "dimension", "$value": "12px" },
    "xl":   { "$type": "dimension", "$value": "16px" },
    "2xl":  { "$type": "dimension", "$value": "24px" },
    "3xl":  { "$type": "dimension", "$value": "32px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 700, "fontSize": "40px", "lineHeight": "48px", "letterSpacing": "-0.02em" }
    },
    "h1": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 700, "fontSize": "32px", "lineHeight": "40px", "letterSpacing": "-0.02em" }
    },
    "h2": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 700, "fontSize": "28px", "lineHeight": "36px", "letterSpacing": "-0.01em" }
    },
    "h3": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 600, "fontSize": "24px", "lineHeight": "32px", "letterSpacing": "-0.01em" }
    },
    "h4": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 600, "fontSize": "20px", "lineHeight": "28px", "letterSpacing": "0em" }
    },
    "h5": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 600, "fontSize": "18px", "lineHeight": "26px", "letterSpacing": "0em" }
    },
    "bodyLg": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 400, "fontSize": "18px", "lineHeight": "28px", "letterSpacing": "0em" }
    },
    "body": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 400, "fontSize": "16px", "lineHeight": "24px", "letterSpacing": "0em" }
    },
    "bodySm": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 400, "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "0em" }
    },
    "label": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 500, "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "0em" }
    },
    "caption": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 400, "fontSize": "12px", "lineHeight": "16px", "letterSpacing": "0.01em" }
    },
    "micro": {
      "$type": "typography",
      "$value": { "fontFamily": "-apple-system", "fontWeight": 500, "fontSize": "11px", "lineHeight": "14px", "letterSpacing": "0.04em" }
    }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": "none" },
    "sm":   { "$type": "shadow", "$value": "0 1px 2px 0 rgb(0 0 0 / 0.04)" },
    "md":   { "$type": "shadow", "$value": "0 2px 6px -1px rgb(0 0 0 / 0.06), 0 1px 2px -1px rgb(0 0 0 / 0.04)" },
    "lg":   { "$type": "shadow", "$value": "0 8px 16px -4px rgb(0 0 0 / 0.08), 0 2px 4px -2px rgb(0 0 0 / 0.04)" },
    "xl":   { "$type": "shadow", "$value": "0 16px 32px -8px rgb(0 0 0 / 0.12), 0 4px 8px -4px rgb(0 0 0 / 0.06)" },
    "2xl":  { "$type": "shadow", "$value": "0 24px 48px -12px rgb(0 0 0 / 0.18)" }
  },
  "motion": {
    "duration": {
      "instant": { "$type": "duration", "$value": "0ms" },
      "fast":    { "$type": "duration", "$value": "150ms" },
      "base":    { "$type": "duration", "$value": "200ms" },
      "slow":    { "$type": "duration", "$value": "300ms" },
      "slower":  { "$type": "duration", "$value": "500ms" }
    }
  },
  "mobile": {
    "touchTarget": {
      "min":         { "$type": "dimension", "$value": "44px" },
      "comfortable": { "$type": "dimension", "$value": "48px" }
    },
    "safeArea": {
      "top":    { "$type": "dimension", "$value": "47px" },
      "bottom": { "$type": "dimension", "$value": "34px" }
    },
    "tabBar":     { "height": { "$type": "dimension", "$value": "49px" } },
    "appBar":     { "height": { "$type": "dimension", "$value": "44px" } }
  }
}
