# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# OAuth (Apple + Google): aktiver providers i Supabase Dashboard → Authentication → Providers.
# Tilføj redirect URL: https://functionalfoods.dk/auth/callback og http://localhost:3000/auth/callback

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_ASSISTANT_FAMILIEMAD=your_assistant_id
OPENAI_ASSISTANT_KETO=your_assistant_id
OPENAI_ASSISTANT_SENSE=your_assistant_id
OPENAI_ASSISTANT_GLP1=your_assistant_id
OPENAI_ASSISTANT_ANTIINFLAMMATORISK=your_assistant_id
OPENAI_ASSISTANT_FLEKSITARISK=your_assistant_id
OPENAI_ASSISTANT_5_2=your_assistant_id
OPENAI_ASSISTANT_PROTEINRIG_KOST=your_assistant_id

# GOMA (primary for all non-Salling/REMA chains — jul 2026)
GOMA_IMPORT_ENABLED=true         # Påkrævet på Vercel + GitHub Actions fooddata-import
# GOMA_API_KEY=                  # Vercel + Goma cron (skriver til GROCERY Supabase)
# GROCERY_TJEK_DISABLED=true     # Anbefalet: stop Tjek-scrape når Goma er primær
# GOMA_SIMULATE_GONE=true        # lokalt uden Goma: simuler gammel prod-adfærd
# GOMA_LEGACY_DATA_ENABLED=true  # kun nød: legacy Goma product IDs i prissøgning
GOMA_API_KEY=your_goma_api_key

# Site Configuration (optional)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=

# Stripe (abonnementer – Madbudget 29 kr / Premium 249 kr)
# Se docs/STRIPE_SETUP.md for webhook og test.
# Verificér lokalt: GET http://localhost:3000/api/stripe/status (viser om nøgler er sat, uden at lække dem)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare Turnstile – widget på /kom-i-gang og "Opret konto" i modal (signup), ikke i login-formen.
#
# VIGTIGT: Supabase har kun én global "Enable Captcha protection" under Authentication → Bot and Abuse Protection.
# Er den TIL, kræver ALLE password-login/signup et captcha-token – login fejler uden Turnstile i UI.
# Er den FRA, virker login uden token; signup bruger stadig Turnstile i appen (token sendes til signUp).
# Der findes ikke "kun signup" i Supabase-dashboard – slå global fra for login uden Turnstile, eller
# vis Turnstile ved både login og signup (begge dele matcher Supabase når global er TIL).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Fooddata / Grocery API (separat Supabase-projekt — docs/FOODDATA_API.md)
GROCERY_SUPABASE_URL=
GROCERY_SUPABASE_PUBLISHABLE_KEY=
GROCERY_SUPABASE_SECRET_KEY=
GROCERY_INTERNAL_API_KEY=
GROCERY_SYNC_SECRET=
# GROCERY_API_BASE_URL=http://localhost:3000


