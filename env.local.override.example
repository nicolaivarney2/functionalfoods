# =============================================================
#  LOKAL OVERRIDE — overlever `npm run env:pull`
# =============================================================
#
# Hvorfor denne fil eksisterer:
# Vercel marker secret keys som "Sensitive". Dem kan `vercel env pull`
# IKKE læse tilbage — de kommer som tomme strings. Production virker
# fint (Vercel injicerer dem ved runtime), men din .env.local mangler
# værdierne efter hvert pull.
#
# Brug:
#   cp env.local.override.example .env.local.override
#   # Udfyld nedenfor med rigtige værdier fra dashboards
#   npm run env:pull   # merger automatisk override ind
#
# =============================================================
# SECRETS DER ER PÅ VERCEL MEN IKKE KAN PULLES (sensitive)
# =============================================================
# Hent fra: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Hent fra: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Hent fra: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Generér med: openssl rand -base64 32
NEXTAUTH_SECRET=
CRON_SECRET=

# Goma (sunset — production bruger kun fooddata automatisk)
# GOMA_IMPORT_ENABLED=true       # kun nød-genaktivering
# GOMA_SIMULATE_GONE=true        # lokalt: samme adfærd som production
# GOMA_LEGACY_DATA_ENABLED=true  # nød: genaktiver legacy Goma
GOMA_API_KEY=sb_publishable_5oBbD8YuxtVjYKBx4pNJzg_hOe593yN

# Hent fra de respektive dashboards
MANYCHAT_API_KEY=
MANYCHAT_WEBHOOK_SECRET=
MS_DK_API_KEY=
SMS_DK_API_KEY=

# =============================================================
# KEYS DER ALDRIG HAR VÆRET PÅ VERCEL (kun lokalt)
# =============================================================
# Grocery service (separat Supabase-projekt)
GROCERY_SUPABASE_URL=https://kuwqzodesppknbjtrsgs.supabase.co
GROCERY_SUPABASE_PUBLISHABLE_KEY=
GROCERY_SUPABASE_SECRET_KEY=
GROCERY_INTERNAL_API_KEY=
GROCERY_SYNC_SECRET=
GROCERY_SUPABASE_DB_PASSWORD=

